      "destination": "/codegraftai/",
      "basePath": false,
      "internal": true,
      "statusCode": 308,
      "regex": "^/codegraftai$"
    },
    {
      "source": "/:file((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+)/",
      "destination": "/:file",
      "internal": true,
      "missing": [
        {
          "type": "header",
